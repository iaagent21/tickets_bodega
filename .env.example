# =============================================================
#  tickets_bodega — Archivo de configuración de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env a GitHub.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Puedes usar la ANON KEY (recomendado) o la SERVICE ROLE KEY.
#
# ANON KEY: es la clave pública de tu proyecto. Solo permite
#   lo que tus políticas RLS permitan. Más seguro para PC en
#   bodega. La encuentras en:
#   Supabase → Settings → API → "anon public"
#
# SERVICE ROLE KEY: tiene acceso total ignorando RLS. Úsala
#   solo si tienes problemas de permisos y el entorno es seguro.
#   La encuentras en:
#   Supabase → Settings → API → "service_role secret"
#
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx

# ── Cuenta de usuario de tienda ───────────────────────────────
# Usuario con permisos para leer pedidos y consultar la API.
STORE_USER_EMAIL=usuario@tienda.com
STORE_USER_PASSWORD=ContraseñaSegura123

# ── API de picking ────────────────────────────────────────────
API_URL=https://mi-api.ejemplo.com

# ── Configuración de tienda ───────────────────────────────────
# PEDIDOS_TABLE: nombre exacto de la tabla en Supabase que contiene
#   los pedidos de esta tienda. Ejemplo: pedidos_la4ta, pedidos_surti
#
# TIENDA: identificador corto de la tienda que se pasa a la API.
#   Ejemplo: la4ta, surti, der, h79
#
# ⚡ Para configurar el script para otra tienda, solo cambia
#   estos dos valores y reinicia con: node listener.js
#
PEDIDOS_TABLE=pedidos_la4ta
TIENDA=la4ta

# ── Opciones adicionales ──────────────────────────────────────
# DRY_RUN=true → solo muestra logs, no genera PDF (útil para pruebas)
DRY_RUN=false

# ── Impresión automática (Impresora Térmica) ─────────────────
# AUTO_PRINT: true para enviar automáticamente el PDF a la impresora, false para solo guardar el archivo PDF
AUTO_PRINT=false

# PRINTER_NAME: Nombre exacto de la impresora de tickets en Windows.
#   Ejemplo: PRINTER_NAME=POS-80C
#   Deja este valor vacío o coméntalo para usar la impresora predeterminada del sistema.
#   Para obtener la lista de impresoras ejecuta en cmd: wmic printer get name
PRINTER_NAME=

